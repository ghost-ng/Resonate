{
  "name": "resonate",
  "productName": "Resonate",
  "version": "0.1.4",
  "description": "Desktop recording and note-taking app",
  "main": ".vite/build/index.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "version:patch": "npm version patch --no-git-tag-version && node -e \"const fs=require('fs');const p=require('./package.json');const c='src/shared/constants.ts';fs.writeFileSync(c,fs.readFileSync(c,'utf8').replace(/APP_VERSION = '[^']+'/,`APP_VERSION = '${p.version}'`))\"",
    "version:minor": "npm version minor --no-git-tag-version && node -e \"const fs=require('fs');const p=require('./package.json');const c='src/shared/constants.ts';fs.writeFileSync(c,fs.readFileSync(c,'utf8').replace(/APP_VERSION = '[^']+'/,`APP_VERSION = '${p.version}'`))\"",
    "version:major": "npm version major --no-git-tag-version && node -e \"const fs=require('fs');const p=require('./package.json');const c='src/shared/constants.ts';fs.writeFileSync(c,fs.readFileSync(c,'utf8').replace(/APP_VERSION = '[^']+'/,`APP_VERSION = '${p.version}'`))\""
  },
  "keywords": [],
  "author": {
    "name": "ghost-ng",
    "email": "21272239+ghost-ng@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "41.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.5.0",
    "vite": "^5.4.21",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "better-sqlite3": "^12.8.0",
    "electron-squirrel-startup": "^1.0.1",
    "native-recorder-nodejs": "^1.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "zustand": "^5.0.0"
  }
}
